generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum MessageRole {
  user
  assistant
  system
  tool
}

enum MemoryType {
  preference
  fact
  reminder
  note
  system
}

enum TaskStatus {
  pending
  in_progress
  done
  canceled
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TriggerType {
  manual
  webhook
  schedule
  ai_command
}

enum ActionType {
  n8n
  whatsapp
  home_assistant
  internal
}

enum AutomationLogStatus {
  success
  error
  pending
}

enum SystemLogLevel {
  info
  warning
  error
  security
}

enum WhatsAppDirection {
  inbound
  outbound
}

enum NotificationType {
  info
  success
  warning
  error
}

enum BankAccountType {
  personal
  business
  savings
  checking
  credit
  other
}

enum FinancialCategoryType {
  income
  expense
  transfer
  adjustment
}

enum FinancialTransactionType {
  income
  expense
  transfer
  adjustment
}

enum FinancialDirection {
  in
  out
  unknown
}

enum FinancialTransactionSource {
  manual
  chat
  statement_import
  automation
}

enum FinancialTransactionStatus {
  confirmed
  pending_review
  ignored
  duplicate
}

enum StatementFileType {
  csv
  ofx
  pdf
  txt
  xlsx
  unknown
}

enum StatementImportStatus {
  uploaded
  parsed
  review_required
  imported
  failed
}

enum StatementImportRowStatus {
  pending
  approved
  ignored
  duplicate
  error
  imported
}

enum AssistantDraftActionType {
  financial_transaction
  bank_account
  statement_import
}

enum AssistantDraftActionStatus {
  collecting
  awaiting_confirmation
  completed
  canceled
}

enum IntegrationEventStatus {
  pending
  sent
  failed
  ignored
}

enum IntegrationEventTarget {
  n8n
  internal
  whatsapp
  other
}

enum DocumentSource {
  upload
  whatsapp
  manual
}

enum DocumentStatus {
  uploaded
  parsed
  indexed
  failed
}

model User {
  id                    String                 @id @default(cuid())
  name                  String
  email                 String                 @unique
  passwordHash          String
  role                  UserRole               @default(user)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  conversations         Conversation[]
  memories              Memory[]
  tasks                 Task[]
  automations           Automation[]
  routines              Routine[]
  notifications         Notification[]
  bankAccounts          BankAccount[]
  financialCategories   FinancialCategory[]
  financialTransactions FinancialTransaction[]
  statementImports      StatementImport[]
  financialRules        FinancialRule[]
  assistantDraftActions AssistantDraftAction[]
  integrationEvents     IntegrationEvent[]
  documents             Document[]
  systemLogs            SystemLog[]
  settings              Setting[]
  whatsappMessages      WhatsAppMessage[]
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  metadata       Json?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Memory {
  id         String           @id @default(cuid())
  userId     String
  type       MemoryType       @default(note)
  title      String
  content    String
  tags       String[]
  importance Int              @default(3)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  embedding  MemoryEmbedding?
}

model MemoryEmbedding {
  id        String   @id @default(cuid())
  memoryId  String   @unique
  provider  String
  model     String
  vector    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  memory    Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
}

model Task {
  id                String       @id @default(cuid())
  userId            String
  title             String
  description       String?
  dueDate           DateTime?
  reminderAt        DateTime?
  reminderSentAt    DateTime?
  overdueNotifiedAt DateTime?
  status            TaskStatus   @default(pending)
  priority          TaskPriority @default(medium)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Routine {
  id          String       @id @default(cuid())
  userId      String
  name        String
  description String?
  triggerType TriggerType  @default(manual)
  config      Json
  enabled     Boolean      @default(true)
  lastRunAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs        RoutineRun[]
}

model RoutineRun {
  id        String   @id @default(cuid())
  routineId String
  status    String
  input     Json?
  output    Json?
  error     String?
  createdAt DateTime @default(now())
  routine   Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(info)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Automation {
  id          String          @id @default(cuid())
  userId      String
  name        String
  description String?
  triggerType TriggerType     @default(manual)
  actionType  ActionType
  config      Json
  enabled     Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs        AutomationLog[]
}

model AutomationLog {
  id           String              @id @default(cuid())
  automationId String
  status       AutomationLogStatus @default(pending)
  input        Json?
  output       Json?
  error        String?
  createdAt    DateTime            @default(now())
  automation   Automation          @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

model SystemLog {
  id        String         @id @default(cuid())
  userId    String?
  level     SystemLogLevel @default(info)
  module    String
  action    String
  message   String
  metadata  Json?
  createdAt DateTime       @default(now())
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Setting {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model WhatsAppMessage {
  id         String            @id @default(cuid())
  userId     String?
  phone      String
  direction  WhatsAppDirection
  content    String
  status     String
  rawPayload Json?
  createdAt  DateTime          @default(now())
  user       User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model BankAccount {
  id               String                 @id @default(cuid())
  userId           String
  bankName         String
  bankCode         String?
  accountType      BankAccountType        @default(checking)
  accountName      String
  agency           String?
  accountNumber    String?
  currentBalance   Decimal                @default(0) @db.Decimal(14, 2)
  currency         String                 @default("BRL")
  active           Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     FinancialTransaction[]
  statementImports StatementImport[]

  @@index([userId, bankName, accountName])
}

model FinancialCategory {
  id           String                 @id @default(cuid())
  userId       String
  name         String
  type         FinancialCategoryType
  parentId     String?
  color        String?
  icon         String?
  keywords     String[]
  isDefault    Boolean                @default(false)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       FinancialCategory?     @relation("FinancialCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     FinancialCategory[]    @relation("FinancialCategoryTree")
  transactions FinancialTransaction[]
  importRows   StatementImportRow[]
  rules        FinancialRule[]

  @@unique([userId, name, type])
  @@index([userId, type])
}

model FinancialTransaction {
  id                    String                     @id @default(cuid())
  userId                String
  bankAccountId         String
  categoryId            String?
  type                  FinancialTransactionType
  direction             FinancialDirection
  amount                Decimal                    @db.Decimal(14, 2)
  date                  DateTime
  description           String
  originalDescription   String
  origin                String
  counterpartyName      String?
  documentNumber        String?
  transactionExternalId String?
  source                FinancialTransactionSource @default(manual)
  status                FinancialTransactionStatus @default(confirmed)
  notes                 String?
  metadata              Json?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  user                  User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount           BankAccount                @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  category              FinancialCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([bankAccountId, date])
  @@index([transactionExternalId])
}

model StatementImport {
  id               String                @id @default(cuid())
  userId           String
  bankAccountId    String?
  fileName         String
  fileType         StatementFileType
  bankNameDetected String?
  accountDetected  String?
  periodStart      DateTime?
  periodEnd        DateTime?
  status           StatementImportStatus @default(uploaded)
  totalRows        Int                   @default(0)
  importedRows     Int                   @default(0)
  duplicateRows    Int                   @default(0)
  reviewRows       Int                   @default(0)
  error            String?
  metadata         Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount      BankAccount?          @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  rows             StatementImportRow[]

  @@index([userId, status])
}

model StatementImportRow {
  id                 String                   @id @default(cuid())
  importId           String
  date               DateTime?
  description        String
  amount             Decimal?                 @db.Decimal(14, 2)
  direction          FinancialDirection       @default(unknown)
  balanceAfter       Decimal?                 @db.Decimal(14, 2)
  categorySuggestion String?
  categoryId         String?
  status             StatementImportRowStatus @default(pending)
  raw                Json
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  import             StatementImport          @relation(fields: [importId], references: [id], onDelete: Cascade)
  category           FinancialCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([importId, status])
}

model FinancialRule {
  id         String              @id @default(cuid())
  userId     String
  name       String
  matchText  String
  categoryId String
  direction  FinancialDirection?
  active     Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   FinancialCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId, active])
}

model AssistantDraftAction {
  id        String                     @id @default(cuid())
  userId    String
  type      AssistantDraftActionType
  status    AssistantDraftActionStatus @default(collecting)
  payload   Json
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt
  user      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, type])
}

model IntegrationEvent {
  id              String                 @id @default(cuid())
  userId          String?
  type            String
  status          IntegrationEventStatus @default(pending)
  payloadRedacted Json
  target          IntegrationEventTarget @default(internal)
  attempts        Int                    @default(0)
  lastError       String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  user            User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, status])
  @@index([userId, createdAt])
}

model Document {
  id        String          @id @default(cuid())
  userId    String
  title     String
  fileName  String
  fileType  String
  source    DocumentSource  @default(upload)
  status    DocumentStatus  @default(uploaded)
  summary   String?
  metadata  Json?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks    DocumentChunk[]

  @@index([userId, status])
}

model DocumentChunk {
  id              String   @id @default(cuid())
  documentId      String
  chunkIndex      Int
  content         String
  contentRedacted String
  embedding       Json?
  metadata        Json?
  createdAt       DateTime @default(now())
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
}
