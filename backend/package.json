{
  "name": "jarvis-home-ai-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "seed:personal": "tsx prisma/seed-personal-profile.ts",
    "create:admin": "tsx scripts/create-admin.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:seed": "tsc --noEmit --module NodeNext --moduleResolution NodeNext --target ES2022 --skipLibCheck --esModuleInterop prisma/seed.ts prisma/seed-personal-profile.ts",
    "validate": "npm run prisma:generate && npm run typecheck && npm run typecheck:seed && npm run test && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "tsx": "^4.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
